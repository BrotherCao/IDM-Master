{
  "manifest_version": 3,
  "name": "IDM Master",
  "version": "0.1.0",
  "description": "IDM Master 下载管理器 — 高速多线程下载 (Firefox)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "idm-master@firefox.addons",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "downloads",
    "cookies",
    "contextMenus",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:16888/*"
  ],
  "background": {
    "scripts": ["background/browser-polyfill.js", "background/service-worker.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "IDM Master"
  }
}
